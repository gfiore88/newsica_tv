YOUTUBE_STREAM_URL=rtmp://a.rtmp.youtube.com/live2
YOUTUBE_STREAM_KEY=inserisci_qui_la_tua_stream_key_di_youtube
YOUTUBE_CHANNEL_ID=yt_idchannel
YOUTUBE_HANDLE=yt_handle_con_chiocciola
YOUTUBE_CHAT_USE_API=false

NEWSICA_SHOW_MUSIC_PILL=1
NEWSICA_SHOW_ON_AIR_PANEL=1
NEWSICA_SHOW_CLOCK_PANEL=1
NEWSICA_SHOW_SCHEDULE_TIMELINE=1
NEWSICA_SHOW_TICKER=1
NEWSICA_ENABLE_COLOR_TICKER=1

# Telegram Integration
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_ADMIN_USERNAME=your_telegram_username_here
TELEGRAM_AUTO_APPROVE=false

# Social Publishing Integration
AUTO_POST_SHORTS=false
SHORTS_DAILY_AUTONOMY_ENABLED=true
SHORTS_TIMEZONE=Europe/Rome
SHORTS_DAILY_DAWN_TIME=05:30
SHORTS_DAILY_MAX_ITEMS=6
SHORTS_GENERATION_LEAD_MINUTES=90
SHORTS_BREAKING_EXTRAS_ENABLED=true
SHORTS_BREAKING_MIN_SCORE=70
SHORTS_BREAKING_MAX_AGE_HOURS=8
SHORTS_BREAKING_COOLDOWN_MINUTES=180
SHORTS_BREAKING_SCAN_INTERVAL_SECONDS=600

# YouTube API (OAuth2 Client)
YOUTUBE_CLIENT_ID=your_youtube_client_id_here
YOUTUBE_CLIENT_SECRET=your_youtube_client_secret_here
YOUTUBE_REFRESH_TOKEN=your_youtube_refresh_token_here

# Instagram Graph API
INSTAGRAM_ACCESS_TOKEN=your_instagram_graph_api_access_token_here
INSTAGRAM_ACCOUNT_ID=your_instagram_business_account_id_here

# TikTok Posting API
TIKTOK_CLIENT_KEY=your_tiktok_client_key_here
TIKTOK_CLIENT_SECRET=your_tiktok_client_secret_here
TIKTOK_REFRESH_TOKEN=your_tiktok_refresh_token_here
TIKTOK_ACCESS_TOKEN=your_tiktok_access_token_here

# Buffer & Cloudinary Unified Integration
BUFFER_USE_INTEGRATION=false
BUFFER_ACCESS_TOKEN=your_buffer_access_token_here
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name_here
CLOUDINARY_API_KEY=your_cloudinary_api_key_here
CLOUDINARY_API_SECRET=your_cloudinary_api_secret_here


# Sottotitoli sincronizzati (MMS_FA, ~1.2GB RAM, preciso al ms)
SHORTS_FORCED_ALIGN=false
# Oppure — sistema legacy (zero RAM aggiuntiva, default se non impostato)
# SHORTS_FORCED_ALIGN=false